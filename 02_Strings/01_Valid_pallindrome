class Solution {
public:


    bool isPalindrome(string s) {
        string str;
        for(int i = 0; i<s.size(); i++){
            if(isalnum(s[i])) {
                str.push_back(s[i]);
            }
        }
        for(int i = 0; i<str.size()/2; i++){
            if(tolower(str[i]) == tolower(str[str.size() - i - 1])){
                continue;
            }else return false;
        }      
        return true;
    }
};